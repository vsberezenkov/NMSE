<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NMSE.UI.ViewModels.Panels"
             xmlns:loc="using:NMSE.UI.Localization"
             x:Class="NMSE.UI.Views.Panels.SettlementView"
             x:DataType="vm:SettlementViewModel">

    <Border Classes="card" Padding="16" Margin="4">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="16">
                <TextBlock Text="{loc:Locale settlement.title}" Classes="sectionHeader" />

                <!-- Settlement Selection -->
                <Border Classes="card" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Locale settlement.title}" Classes="sectionHeader" />
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Locale settlement.title}" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding SettlementNames}"
                                      SelectedIndex="{Binding SelectedSettlementIndex}" HorizontalAlignment="Stretch" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Locale settlement.name}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SettlementName}" Margin="0,4,0,0" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Locale settlement.seed}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                <TextBox Text="{Binding SeedValue}" Width="200" />
                                <Button Content="{loc:Locale common.gen}" Command="{Binding GenerateSeedCommand}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Settlement Stats -->
                <Border Classes="card" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Locale player.section_statistics}" Classes="sectionHeader" />
                        <Grid ColumnDefinitions="160,200" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Locale settlement.population}" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Population}" Minimum="0" Maximum="200" Increment="1" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{loc:Locale settlement.happiness}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Happiness}" Minimum="0" Maximum="100" Increment="1" Margin="0,4,0,0" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Locale settlement.productivity}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding Productivity}" Minimum="0" Maximum="100" Increment="1" Margin="0,4,0,0" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{loc:Locale settlement.upkeep}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding Upkeep}" Minimum="0" Maximum="100" Increment="1" Margin="0,4,0,0" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Locale settlement.sentinels}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding Sentinels}" Minimum="0" Maximum="100" Increment="1" Margin="0,4,0,0" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="{loc:Locale settlement.debt}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding Debt}" Minimum="0" Maximum="999999" Increment="100" Margin="0,4,0,0" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Locale settlement.alert}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <NumericUpDown Grid.Row="6" Grid.Column="1" Value="{Binding Alert}" Minimum="0" Maximum="100" Increment="1" Margin="0,4,0,0" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="{loc:Locale settlement.bug_attack}" VerticalAlignment="Center" Margin="0,4,0,0" />
                            <NumericUpDown Grid.Row="7" Grid.Column="1" Value="{Binding BugAttack}" Minimum="0" Maximum="100" Increment="1" Margin="0,4,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Production & Decision -->
                <Border Classes="card" Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{loc:Locale settlement.production_header}" Classes="sectionHeader" />
                        <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Locale settlement.decision_type}" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding DecisionTypes}"
                                      SelectedIndex="{Binding DecisionTypeIndex}" HorizontalAlignment="Stretch" />
                        </Grid>
                        <DataGrid ItemsSource="{Binding ProductionItems}"
                                  AutoGenerateColumns="False" IsReadOnly="False"
                                  SelectionMode="Single" Margin="0,8,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Locale settlement.col_name}" Binding="{Binding ItemName}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="{loc:Locale settlement.col_element_id}" Binding="{Binding ElementId}" Width="200" />
                                <DataGridTextColumn Header="{loc:Locale settlement.col_amount}" Binding="{Binding Amount}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{loc:Locale settlement.delete}" Command="{Binding DeleteSettlementCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
